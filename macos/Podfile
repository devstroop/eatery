platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # --- Native SQLite store spike -------------------------------------------
  # Bundle libeaterystore.dylib (Zig + embedded SQLite) into the app's
  # Frameworks folder so dart:ffi can load it via @rpath. The dylib's install
  # name is already @rpath/libeaterystore.dylib, and the Runner target's
  # runpaths include @executable_path/../Frameworks.
  runner_project_path = File.join(__dir__, 'Runner.xcodeproj')
  runner_project = Xcodeproj::Project.open(runner_project_path)
  runner_target = runner_project.targets.find { |t| t.name == 'Runner' }
  phase_name = 'Bundle libeaterystore'
  if runner_target && runner_target.shell_script_build_phases.none? { |p| p.name == phase_name }
    phase = runner_target.new_shell_script_build_phase(phase_name)
    phase.shell_script = <<~'SCRIPT'
      set -e
      LIB_DIR="$SRCROOT/../libeaterystore"
      LIB="$LIB_DIR/zig-out/lib/libeaterystore.dylib"
      if [ ! -f "$LIB" ]; then
        if command -v zig >/dev/null 2>&1; then
          ( cd "$LIB_DIR" && zig build shared-lib )
        else
          echo "warning: zig not found and $LIB missing — skipping bundle"
          exit 0
        fi
      fi
      DEST="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}"
      mkdir -p "$DEST"
      cp -f "$LIB" "$DEST/libeaterystore.dylib"
      if [ -n "${EXPANDED_CODE_SIGN_IDENTITY:-}" ]; then
        codesign --force --timestamp=none --sign "${EXPANDED_CODE_SIGN_IDENTITY}" "$DEST/libeaterystore.dylib" || true
      fi
    SCRIPT
    runner_project.save
  end
end
